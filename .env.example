# 复制本文件为 .env，填入你自己的 key。.env 已在 .gitignore，不会被提交。
#   cp .env.example .env

# Google Gemini API Key（默认用这个；在 https://aistudio.google.com/apikey 免费申请）
GOOGLE_API_KEY=

# OpenAI / OpenRouter Key（仅当你在 notebook 第 5 步改用 OpenAI 时才需要）
# OPENAI_API_KEY=
# 用 OpenRouter 的话再加一行 base：
# OPENAI_API_BASE=https://openrouter.ai/api/v1
